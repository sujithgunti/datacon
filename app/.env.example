# ── Database (Supabase Postgres — create a project at supabase.com and paste its
#    connection string here; used by both Prisma/NestJS and Prisma migrations) ──
DATABASE_URL="postgresql://postgres:password@localhost:5432/datacon"

# ── Auth ──
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# ── Connector secret encryption (32 random bytes, base64) ──
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CONNECTOR_ENCRYPTION_KEY="change-me-32-byte-base64-key"

# ── CORS ──
CORS_ORIGINS="http://localhost:5173"

# ── Service ports / URLs ──
PORT=4000
AI_SERVICE_URL="http://localhost:8000"
INTERNAL_AUTH_TOKEN="dev-internal-token"

# ── AI service (ai/) ──
CHROMA_URL="http://localhost:8001"
CHROMA_PERSIST_DIR="./.chroma"

# Optional: set to enable real LLM responses (via LiteLLM) instead of the
# offline fallback. LLM_MODEL is a LiteLLM "provider/model" string — the
# provider prefix determines which *_API_KEY LiteLLM reads (GEMINI_API_KEY
# for "gemini/", ANTHROPIC_API_KEY for "anthropic/", etc.), so switching
# providers/models is just editing these two values.
GEMINI_API_KEY=""
LLM_MODEL="gemini/gemini-2.5-flash"

# ── Sample external DB connectors (docker-compose local instances) ──
SAMPLE_POSTGRES_URL="postgresql://analyst:analyst@localhost:55432/analytics"
SAMPLE_MYSQL_URL="mysql://analyst:analyst@localhost:53306/analytics"
SAMPLE_MONGO_URL="mongodb://analyst:analyst@localhost:57017/analytics"
