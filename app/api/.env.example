# ── Database (Supabase Postgres — create a project at supabase.com and paste its
#    connection string here; used by both Prisma/NestJS and Prisma migrations) ──
DATABASE_URL="postgresql://postgres:password@localhost:5432/datacon"

# ── Auth ──
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# ── Connector secret encryption (32 random bytes, base64) ──
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CONNECTOR_ENCRYPTION_KEY="change-me-32-byte-base64-key"

# ── CORS ──
CORS_ORIGINS="http://localhost:5173"

# ── Service ports / URLs ──
PORT=4000
AI_SERVICE_URL="http://localhost:8000"
# Must match INTERNAL_AUTH_TOKEN in ../ai/.env exactly.
INTERNAL_AUTH_TOKEN="dev-internal-token"
