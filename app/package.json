{
  "name": "datacon",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "web",
    "api",
    "packages/*"
  ],
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:web": "npm run dev --workspace=web",
    "dev:api": "npm run start:dev --workspace=api",
    "dev:ai": "cd ai && (test -d .venv && . .venv/bin/activate; uvicorn app.main:app --reload --port 8000)",
    "build": "npm run build --workspace=packages/shared-types && npm run build --workspace=api && npm run build --workspace=web",
    "prisma:generate": "npm run generate --workspace=packages/prisma",
    "prisma:migrate": "npm run migrate --workspace=packages/prisma",
    "prisma:seed": "npm run seed --workspace=packages/prisma",
    "lint": "npm run lint --workspace=web && npm run lint --workspace=api"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3"
  }
}
